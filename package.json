{
  "name": "inkwell",
  "version": "1.0.1",
  "description": "Write novels, screenplays, and other long projects in Obsidian (https://obsidian.md). Derived from Longform by Kevin Barrett (kevboh).",
  "keywords": [],
  "license": "MIT",
  "author": "Dwi Elfianto",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "vp build --watch",
    "build": "vp build",
    "check": "vp fmt --check -c .oxfmtrc.json && vp lint -c .oxlintrc.json",
    "lint": "vp lint -c .oxlintrc.json",
    "lint:fix": "vp lint -c .oxlintrc.json --fix",
    "format": "vp fmt --write -c .oxfmtrc.json",
    "type-check": "bun x tsc --noEmit && bun x svelte-check --tsconfig tsconfig.json",
    "test": "vp test run",
    "test:coverage": "vp test run --coverage"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "sortablejs": "^1.15.7"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@types/node": "^26.1.1",
    "@types/sortablejs": "^1.15.9",
    "@voidzero-dev/vite-plus-core": "^0.2.4",
    "builtin-modules": "^5.3.0",
    "obsidian": "^1.13.1",
    "svelte": "^5.56.5",
    "svelte-check": "^4.7.3",
    "tslib": "^2.8.1",
    "typescript": "^7.0.2",
    "vite-plus": "^0.2.4",
    "vitest": "4.1.10"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.2.4"
  }
}
